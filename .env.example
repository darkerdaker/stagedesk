# Yamaha DM7 network settings
DM7_IP=192.168.1.100
DM7_OSC_PORT=49280

# node-midi device index (run `node -e "const m=require('midi');const i=new m.Input();for(let n=0;n<i.getPortCount();n++)console.log(n,i.getPortName(n))"` to list)
MIDI_DEVICE_INDEX=0

# Express server port
BRIDGE_PORT=3000

# Shure ULXD receivers — comma-separated IPs
ULXD_IPS=192.168.1.20,192.168.1.21
ULXD_PORT=2202

# Pushover push notifications (battery alerts)
# Create an app at https://pushover.net to get a token
# Use a group key to notify the whole crew at once
PUSHOVER_TOKEN=your_app_api_token
PUSHOVER_GROUP=your_delivery_group_key

# Battery alert thresholds (ULXD BATT_BARS scale: 0–5)
BATTERY_WARN_BARS=2
BATTERY_CRITICAL_BARS=1
